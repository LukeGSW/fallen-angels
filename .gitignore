# NOTE: cache/ is intentionally NOT ignored.
# GitHub Actions commits the pre-computed Parquet files
# so Streamlit Cloud can read them without running the pipeline.
# cache/*.parquet  <-- tracked by git
# cache/*.json     <-- tracked by git
